map $http_x_forwarded_proto $proxy_xfp {
  default $http_x_forwarded_proto;
  ""      $scheme;
}

 
map $http_upgrade $connection_upgrade {
  default upgrade;
  ""      close;
}

server {
  listen 80;
  server_name i13c208.p.ssafy.io;
  root /usr/share/nginx/html;
  index index.html;


  add_header Cross-Origin-Opener-Policy same-origin always;
  add_header Cross-Origin-Embedder-Policy require-corp always;


  client_max_body_size 20m;


  location / {
    try_files $uri $uri/ /index.html;
  }


  location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
    expires 1y;
    add_header Cache-Control "public, immutable";
    add_header Cross-Origin-Opener-Policy same-origin always;
    add_header Cross-Origin-Embedder-Policy require-corp always;
    try_files $uri =404;
  }

  location ^~ /api/ {
    proxy_http_version 1.1;
    proxy_set_header Host               $host;
    proxy_set_header X-Forwarded-Host   $host;
    proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto  $proxy_xfp;
    proxy_set_header X-Real-IP          $remote_addr;

    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
    proxy_buffering off;
    proxy_redirect  off;

    proxy_pass http://backend-service.ddoit.svc.cluster.local:8080;
  }

  location ^~ /ws/ {
    proxy_http_version 1.1;
    proxy_set_header Upgrade            $http_upgrade;
    proxy_set_header Connection         $connection_upgrade;
    proxy_set_header Host               $host;
    proxy_set_header X-Forwarded-Host   $host;
    proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto  $proxy_xfp;

    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
    proxy_buffering off;
    proxy_redirect  off;

    proxy_pass http://backend-service.ddoit.svc.cluster.local:8080;
  }

  # gzip
  gzip on;
  gzip_types
    text/plain text/css text/javascript application/javascript
    application/json text/xml application/xml application/xml+rss;
}
